{
  "name": "lead-engine",
  "version": "0.1.0",
  "private": true,
  "description": "AI Ark lead-engine: 6-stage lead enrichment + PlusVibe upload + Supabase upsert with OpenAI ICP and competitor discovery.",
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "start": "tsx index.ts",
    "dev": "tsx watch index.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.json",
    "shards": "tsx scripts/run-parallel-shards.ts",
    "validate:csv": "tsx scripts/validate-leads-csv.ts",
    "run:healthcare": "bash scripts/run-healthcare-upload.sh"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "axios": "^1.7.7",
    "csv-parse": "^5.5.6",
    "csv-stringify": "^6.5.1",
    "dotenv": "^16.4.5",
    "openai": "^4.67.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  }
}
